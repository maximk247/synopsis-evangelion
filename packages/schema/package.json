{
  "name": "@synopsis/schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/synopsis.ts"
  },
  "types": "./src/synopsis.ts",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
