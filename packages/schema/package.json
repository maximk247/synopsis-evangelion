    "validate": "tsx scripts/validate.ts",
    "gen:schema": "tsx scripts/gen-jsonschema.ts"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod-to-json-schema": "^3.24.1"
  }
}
