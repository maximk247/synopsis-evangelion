{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "svelte-kit sync",
    "predev": "node scripts/prepare-data.mjs",
    "dev": "vite dev",
    "prebuild": "node scripts/prepare-data.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "pretest": "node scripts/prepare-data.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "node scripts/prepare-data.mjs && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check ."
  },
  "devDependencies": {
    "@fontsource-variable/alegreya": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@synopsis/schema": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^22.0.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
